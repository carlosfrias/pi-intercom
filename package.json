{
  "name": "pi-intercom",
  "version": "0.6.0",
  "license": "MIT",
  "type": "module",
  "main": "src/index.ts",
  "files": [
    "src/index.ts",
    "src/types.ts",
    "src/config.ts",
    "src/reply-tracker.ts",
    "src/broker/**/*.ts",
    "src/ui/**/*.ts",
    "src/skills/**/*"
  ],
  "scripts": {
    "test": "tsx --test broker/paths.test.ts broker/spawn.test.ts reply-tracker.test.ts intercom.integration.test.ts test/inline-message.test.ts",
    "test:unit": "tsx tests/concurrent-ask.unit.test.ts",
    "test:live": "echo 'Run tests/concurrent-ask.test.ts or tests/parallel-ask-live.test.ts inside a pi session with intercom loaded'"
  },
  "keywords": [
    "pi-package"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ],
    "skills": [
      "./src/skills"
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*"
  },
  "dependencies": {
    "tsx": "^4.20.0",
    "typebox": "^1.1.24"
  }
}
